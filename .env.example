# GraphQL API – per environment (Vite loads .env.development / .env.staging / .env.production by mode)
# Development: http://localhost:3000/graphql
# Staging/Production: set to your deployed API URL
VITE_GRAPHQL_ENDPOINT=http://localhost:3000/graphql

# Google reCAPTCHA v3 (public site key). Required in production when the API has RECAPTCHA_SECRET_KEY set.
# VITE_RECAPTCHA_SITE_KEY=

# Optional: browser timeout for chat `ask` (ms). Default 900000 (15 min). Min 60000 if set, or 0 = no client timeout.
# VITE_GRAPHQL_ASK_TIMEOUT_MS=0

# Chat UI: SSE token streaming (POST /api/chat/ask-stream) is the DEFAULT when this variable is omitted or empty.
# Set to 0, false, or off to use GraphQL `ask` only (no streaming).
# VITE_CHAT_STREAM=0
